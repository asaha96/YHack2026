# K2 Think (OpenAI-compatible) — default in code
K2_API_KEY=your_IFM_key_here
# KIMI_BASE_URL=https://api.k2think.ai/v1
# KIMI_MODEL=MBZUAI-IFM/K2-Think-v2
# KIMI_JSON_MODE=1

# To use Moonshot Kimi instead, set e.g.:
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# KIMI_MODEL=kimi-k2.5

# Optional: Groq PlayAI TTS only (/api/narrate, livekit agent speech)
GROQ_API_KEY=

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
